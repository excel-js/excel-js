{
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "tsdown": "0.22.3"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "build": "bun run --parallel --filter='./packages/**' build",
    "test:bun": "bun run --filter='./packages/**' test:bun",
    "test": "bun run --filter='./packages/**' test"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.2",
    "@types/bun": "1.3.14",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "7.0.2"
  }
}
