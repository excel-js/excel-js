{
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "tsdown": "0.22.3"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "build": "bun run --parallel --filter='./packages/**' build",
    "test:bun": "bun run --filter='./packages/**' test:bun",
    "test": "bun run --filter='./packages/**' test"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.1",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3",
    "unrun": "0.3.1"
  }
}
